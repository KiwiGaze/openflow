{
  "name": "@openflow/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "OpenFlow desktop app (Tauri + React).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:vite": "pnpm --filter @openflow/core build && vite",
    "build:vite": "pnpm --filter @openflow/core build && vite build",
    "build": "pnpm run build:vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@openflow/core": "workspace:*",
    "@tauri-apps/api": "^2.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
